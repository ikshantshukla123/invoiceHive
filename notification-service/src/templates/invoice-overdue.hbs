<h1>Friendly reminder — invoice overdue</h1>
<p>Hi {{clientName}},</p>
<p>
  This is a gentle reminder that the following invoice from {{fromName}} is now
  <strong>{{daysOverdue}} day{{#if multipleDays}}s{{/if}} overdue</strong>.
</p>

<div class="warning-box">
  Payment was due on {{dueDate}} and has not yet been received.
</div>

<div class="amount-block">
  <div class="amount-label">Outstanding amount</div>
  <div class="amount-value">{{currency}} {{amount}}</div>
</div>

<div class="detail-row">
  <span class="detail-label">Invoice number</span>
  <span class="detail-value">{{invoiceNumber}}</span>
</div>
<div class="detail-row">
  <span class="detail-label">Original due date</span>
  <span class="detail-value" style="color: #DC2626;">{{dueDate}}</span>
</div>
<div class="detail-row" style="border-bottom: none;">
  <span class="detail-label">Status</span>
  <span class="badge badge-danger">Overdue</span>
</div>

<br/>
{{#if paymentUrl}}
  <a href="{{paymentUrl}}" class="btn">Pay Now — {{currency}} {{amount}}</a>
{{/if}}

<hr class="divider"/>
<p style="font-size: 13px; color: #64748B;">
  If you've already arranged payment with {{fromName}}, please disregard this email.
  Contact {{fromName}} if you have any questions.
</p>
