# ========================================
# REQUIRED ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ========================================

# ── Database ─────────────────────────────────────
# MongoDB connection string
# Get free database at: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/invoicehive?retryWrites=true&w=majority

# OR use local MongoDB (with Docker)
# MONGO_URI=mongodb://localhost:27017/invoicehive

# ── Redis Cache ──────────────────────────────────
# Get free Redis at: https://upstash.com/
REDIS_URL=redis://default:password@hostname:port

# OR use local Redis (with Docker)
# REDIS_URL=redis://localhost:6379

# ── JWT Secrets ──────────────────────────────────
# Generate random strings (use: openssl rand -base64 32)
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
COOKIE_SECRET=your_super_secret_cookie_key_min_32_chars

# Secret for internal service communication
INTERNAL_SECRET=your_internal_service_secret_min_32_chars

# ── URLs ─────────────────────────────────────────
# Frontend URL (for CORS and OAuth callbacks)
CLIENT_URL=http://localhost:3000

# API URL (for frontend to call backend)
NEXT_PUBLIC_API_URL=http://localhost/api

# Storage public URL (for serving PDFs)
STORAGE_PUBLIC_URL=http://localhost:9000

# ── OAuth (Google) ───────────────────────────────
# Get credentials at: https://console.cloud.google.com/
# Create OAuth 2.0 Client ID
# Authorized redirect URIs: http://localhost/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost/api/auth/oauth/google/callback

# ── OAuth (GitHub) ───────────────────────────────
# Get credentials at: https://github.com/settings/developers
# Create New OAuth App
# Authorization callback URL: http://localhost/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost/api/auth/oauth/github/callback

# ── Payment (Razorpay) ───────────────────────────
# Get credentials at: https://dashboard.razorpay.com/
# Dashboard > Settings > API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Email (SMTP) ─────────────────────────────────
# Use Gmail, SendGrid, Mailgun, etc.
# For Gmail: Enable "Less secure app access" or use App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=InvoiceHive <noreply@invoicehive.com>

# ── MinIO (File Storage) ─────────────────────────
# For local development, use defaults
# For production, change these!
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── RabbitMQ (Message Queue) ─────────────────────
# For local development, use defaults
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── Docker (Production Only) ─────────────────────
# Your Docker Hub username (for publishing images)
DOCKER_USERNAME=yourdockerhubusername

# ========================================
# OPTIONAL - ADVANCED CONFIGURATION
# ========================================

# Node environment
NODE_ENV=development

# Service ports (change if conflicts)
# PORT_AUTH=3001
# PORT_CLIENT_SERVICE=3002
# PORT_INVOICE_SERVICE=3003
# PORT_PAYMENT_SERVICE=3004
# PORT_NOTIFICATION_SERVICE=3005

# JWT expiration times
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

# API rate limiting
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# HOW TO GENERATE SECRETS
# ========================================
# Run this command in terminal:
#   openssl rand -base64 32
#
# Or use online generator:
#   https://generate-secret.vercel.app/32
# ========================================
